{
  "expo": {
    "name": "ケーニーズ学童クラブ",
    "slug": "kenies-gakudo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "keniesgakudoapp",
    "userInterfaceStyle": "automatic",
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "config": {
        "pwa": {
          "manifest": {
            "name": "ケーニーズ学童クラブ",
            "short_name": "ケーニーズ",
            "display": "standalone",
            "start_url": "/",
            "background_color": "#ffffff",
            "theme_color": "#FF69B4",
            "icons": [
              {
                "src": "./assets/images/icon.png",
                "sizes": "192x192",
                "type": "image/png"
              },
              {
                "src": "./assets/images/icon.png",
                "sizes": "512x512",
                "type": "image/png"
              }
            ]
          }
        }
      }
    },
    "plugins": [
      "expo-router"
    ]
  }
}